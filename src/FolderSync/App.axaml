<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FolderSync.App"
             xmlns:local="using:FolderSync"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Resources>
        <!-- DESIGN SYSTEM: Color Palette (Clarity-inspired Surface Hierarchy) -->
        <SolidColorBrush x:Key="BgApp" Color="#1c2b31" />       <!-- Primary Application Background -->
        <SolidColorBrush x:Key="BgPanel" Color="#14283C" />     <!-- Secondary Panel / Table Row Background -->
        <SolidColorBrush x:Key="BgCard" Color="#24303C" />      <!-- Tertiary Card / Overlay Background -->
        <SolidColorBrush x:Key="BgBorder" Color="#546C84" />    <!-- Structural Borders and Dividers -->
        <SolidColorBrush x:Key="BgHover" Color="#30546C" />     <!-- Interaction: Hover State Background -->

        <!-- DESIGN SYSTEM: Semantic Accents -->
        <SolidColorBrush x:Key="AccentBlue" Color="#115f88" />  <!-- Primary Action / Active State -->
        <SolidColorBrush x:Key="AccentGreen" Color="#477413" /> <!-- Success Indicator -->
        <SolidColorBrush x:Key="AccentRed" Color="#8D1707" />   <!-- Updated for WCAG 4.8:1 contrast -->

        <SolidColorBrush x:Key="HoverBlue" Color="#5083A0" />
        <SolidColorBrush x:Key="LightBlue" Color="#7997AB" />

        <!-- DESIGN SYSTEM: Typography -->
        <SolidColorBrush x:Key="TextMain" Color="#e4eaec" />    <!-- Content / Header Text -->
        <SolidColorBrush x:Key="TextMuted" Color="#BDD1DF" />   <!-- Updated to fixed color to avoid Alpha-blending -->


        <!-- ToggleSwitch Style: Knob color in UNCHECKED state -->
        <SolidColorBrush x:Key="ToggleSwitchKnobFillOff" Color="#BDD1DF" />
        <SolidColorBrush x:Key="ToggleSwitchKnobFillOffPointerOver" Color="#BDD1DF" />
        <SolidColorBrush x:Key="ToggleSwitchKnobFillOffPressed" Color="#BDD1DF" />

        <!-- ToggleSwitch Style: Knob color in CHECKED state -->
        <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="#BDD1DF" />
        <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPointerOver" Color="#BDD1DF" />
        <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPressed" Color="#BDD1DF" />

        <!-- DESIGN SYSTEM: Custom Typography Resources -->
        <!-- JetBrains Mono font is provided via Fonts.Avalonia.JetBrainsMono NuGet package -->

    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

        <!-- GLOBAL STYLES: Window and Base Typography -->
        <Style Selector="Window">
            <Setter Property="Background" Value="{StaticResource BgApp}" />
            <Setter Property="FontFamily" Value="JetBrainsMono" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontWeight" Value="SemiLight" />
        </Style>

        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="JetBrainsMono" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <!-- NAVIGATION: TabControl / TabItem Customization -->
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="Margin" Value="0,0,20,0" />
            <Setter Property="Padding" Value="0,10" />
        </Style>


        <Style Selector="TabItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF" />
        </Style>


        <Style Selector="TabItem:pointerover /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="True" />
            <Setter Property="Background" Value="{StaticResource AccentBlue}" />
            <Setter Property="Height" Value="3" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <!-- Ensure visibility and consistency for selected pipe; Avalonia defaults usually handle this. -->
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="True" />
            <Setter Property="Background" Value="{StaticResource AccentBlue}" />
            <Setter Property="Height" Value="3" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <!-- DATA VISUALIZATION: DataGrid Customization -->
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource BgBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BgBorder}" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>

        <!-- UI INTERACTION: Remove default focus adorners to maintain clean aesthetic -->
        <Style Selector="DataGridCell:focus /template/ Grid#FocusVisual">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <!-- COMPONENT: DataGrid Column Headers -->
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource BgCard}" />
            <Setter Property="Foreground" Value="{StaticResource TextMain}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,12" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="BorderBrush" Value="{StaticResource BgBorder}" />
            <Setter Property="SeparatorBrush" Value="{StaticResource BgBorder}" />
        </Style>

        <!-- COMPONENT: DataGrid Rows (Interaction States) -->
        <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{StaticResource BgPanel}" />
        </Style>
        <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{StaticResource BgHover}" />
        </Style>

        <!-- COMPONENT: Buttons - Solid Variation -->
        <Style Selector="Button.solid">
            <Setter Property="Background" Value="{StaticResource AccentBlue}" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.solid:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource HoverBlue}" />
            <Setter Property="TextBlock.Foreground" Value="White" />
        </Style>

        <!-- COMPONENT: Buttons - Outline Variation -->
        <Style Selector="Button.outline">
            <Setter Property="Background" Value="{StaticResource BgPanel}" />
            <Setter Property="BorderBrush" Value="{StaticResource BgBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.outline:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BgHover}" />
            <Setter Property="BorderBrush" Value="{StaticResource TextMuted}" />
            <Setter Property="TextBlock.Foreground" Value="{StaticResource TextMuted}" />
        </Style>

        <!-- ======================================================= -->
        <!-- COMPONENT: ToggleSwitch (Global Design)                 -->
        <!-- ======================================================= -->

        <!-- GLOBAL PROPERTIES: Base sizing and appearance -->
        <Style Selector="ToggleSwitch">
            <!-- Scales the element to 90% while maintaining vector sharpness -->
            <Setter Property="RenderTransform" Value="scale(0.9)" />
            <!-- Compensation for scaling effect on text size (optional) -->
            <Setter Property="FontSize" Value="16" />
        </Style>

        <!-- ================= TRACK COLORS ===================== -->

        <!-- Style for CHECKED state -->
        <Style Selector="ToggleSwitch:checked /template/ Border#SwitchKnobBounds">
            <Setter Property="Background" Value="{StaticResource AccentBlue}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}" />
        </Style>

        <!-- Style for PointerOver in CHECKED state -->
        <Style Selector="ToggleSwitch:checked:pointerover /template/ Border#SwitchKnobBounds">
            <Setter Property="Background" Value="{StaticResource HoverBlue}" />
            <Setter Property="BorderBrush" Value="{StaticResource HoverBlue}" />
        </Style>

        <!-- Style for Pressed in CHECKED state -->
        <Style Selector="ToggleSwitch:checked:pressed /template/ Border#SwitchKnobBounds">
            <Setter Property="Background" Value="{StaticResource AccentBlue}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}" />
        </Style>

        <!-- ANIMATION: Rotating status indicator -->
        <Style Selector="PathIcon.spinning">
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Application.Styles>
</Application>