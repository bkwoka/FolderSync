<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FolderSync.ViewModels"
             xmlns:models="using:FolderSync.Models"
             xmlns:i18N="using:FolderSync.MarkupExtensions"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="FolderSync.Views.BrowserView"
             x:DataType="vm:BrowserViewModel"
             d:DataContext="{x:Static vm:DesignTimeViewModels.BrowserViewModel}">

    <Panel>
        <!-- LAYER 1: Main Content Interface -->
        <Grid RowDefinitions="Auto, *, Auto" Margin="20" IsEnabled="{Binding !IsAppLocked}">

            <!-- Header Section: Navigation and Control Area -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Spacing="10">
                    <TextBlock Text="{i18N:Localize Browser_Header}" FontSize="20" FontWeight="SemiBold" Margin="0,-10,0,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource LightBlue}" Margin="0,-5,0,5" TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,0,0,10">
                        <!-- Remote Drive Selector -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BgBorder}" BorderThickness="1" CornerRadius="4" Padding="10" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{i18N:Localize Browser_SelectDrive}" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                                <ComboBox ItemsSource="{Binding AvailableRemotes}" 
                                          SelectedItem="{Binding SelectedRemote}" 
                                          Width="200" Background="{StaticResource BgApp}" Foreground="{StaticResource TextMuted}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:RemoteInfo">
                                            <TextBlock Text="{Binding FriendlyName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Read-Only Badge: Visual indicator for secondary remotes -->
                        <Border CornerRadius="10" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BgBorder}" BorderThickness="1" Padding="10,4" Margin="0,4" 
                                IsVisible="{Binding !CanModify}" VerticalAlignment="Center">
                            <TextBlock Text="{i18N:Localize Browser_ReadOnlyMode}" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Filtering Section -->
                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                    <ToggleSwitch IsChecked="{Binding ShowOnlyConversations}" 
                                   OnContent="{i18N:Localize Browser_ToggleChats}" 
                                   OffContent="{i18N:Localize Browser_ToggleAll}"
                                   Foreground="{StaticResource TextMuted}"/>
                </StackPanel>
            </Grid>

            <!-- Content Area: Remote File List -->
            <DataGrid Grid.Row="1" 
                      ItemsSource="{Binding Files}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserResizeColumns="True"
                      MinColumnWidth="60">
                
                <DataGrid.Columns>
                    
                    <!-- COLUMN: Context Actions (Available on Master Drive for AIStudio conversations) -->
                    <DataGridTemplateColumn Header="" MinWidth="55" MaxWidth="55">
                        <DataTemplate x:DataType="models:RcloneItem">
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding $parent[UserControl].((vm:BrowserViewModel)DataContext).CanModify}">
                                <StackPanel Orientation="Horizontal" IsVisible="{Binding IsConversation}">
                                    <!-- Action: Rename -->
                                    <Button Classes="outline" 
                                            Command="{Binding $parent[UserControl].((vm:BrowserViewModel)DataContext).StartRenameCommand}"
                                            CommandParameter="{Binding}"
                                            Padding="2,4" Margin="8, 2, 2, 2" CornerRadius="4" BorderThickness="0"
                                            ToolTip.Tip="{i18N:Localize Tooltip_Rename}">
                                        <PathIcon Data="M3 17.25V21H6.75L17.81 9.94L14.06 6.19L3 17.25ZM20.71 7.04C21.1 6.65 21.1 6.02 20.71 5.63L18.37 3.29C17.98 2.9 17.35 2.9 16.96 3.29L15.13 5.12L18.88 8.87L20.71 7.04Z" 
                                                  Width="16" Height="16" Foreground="{StaticResource AccentBlue}"/>
                                    </Button>
                                    <!-- Action: Delete -->
                                    <Button Classes="outline" 
                                            Command="{Binding $parent[UserControl].((vm:BrowserViewModel)DataContext).StartDeleteCommand}"
                                            CommandParameter="{Binding}"
                                            Padding="2,4" Margin="0" CornerRadius="4" BorderThickness="0"
                                            ToolTip.Tip="{i18N:Localize Tooltip_Delete}">
                                        <PathIcon Data="M16 9V19H8V9H16ZM14.5 3H9.5L8.5 4H5V6H19V4H15.5L14.5 3ZM18 7H6V19C6 20.1 6.9 21 8 21H16C17.1 21 18 20.1 18 19V7Z" 
                                                  Width="16" Height="16" Foreground="{StaticResource AccentRed}"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="{i18N:Localize Browser_ColName}" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="{i18N:Localize Browser_ColDate}" Binding="{Binding ModTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" />
                    
                    <DataGridTemplateColumn Header="{i18N:Localize Browser_ColFormat}" Width="*">
                        <DataTemplate x:DataType="models:RcloneItem">
                            <Border CornerRadius="10" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BgBorder}" BorderThickness="1" Padding="10,4" Margin="0,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding MimeType}" FontSize="11" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Footer: Global Browser Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="{i18N:Localize Btn_Refresh}" Command="{Binding RefreshCommand}" Classes="solid" IsEnabled="{Binding !IsLoading}"/>
            </StackPanel>
        </Grid>

        <!-- LAYER 2: Sync Disruption Warning Overlay -->
        <Border IsVisible="{Binding RenameDialog.IsWarningModalVisible}" ZIndex="100" Background="#aa000000">
            <Border Background="{StaticResource BgPanel}" CornerRadius="8" Padding="25" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="450" MaxWidth="550">
                <StackPanel Spacing="15">
                    <TextBlock Text="{i18N:Localize Warn_SyncTitle}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                    <Border Background="{StaticResource BgApp}" BorderBrush="{StaticResource BgBorder}" BorderThickness="1" Padding="15" CornerRadius="4">
                        <TextBlock Text="{i18N:Localize Warn_SyncDesc}" TextWrapping="Wrap" FontSize="14" Foreground="{StaticResource TextMuted}"/>
                    </Border>
                    <CheckBox IsChecked="{Binding RenameDialog.SkipWarningCheckbox}" Content="{i18N:Localize Checkbox_DontShow}" Foreground="{StaticResource TextMuted}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" >
                        <Button Content="{i18N:Localize Btn_Cancel}" Command="{Binding RenameDialog.CancelRenameCommand}" Classes="outline"/>
                        <Button Content="{i18N:Localize Btn_Continue}" Command="{Binding RenameDialog.ContinueToInputCommand}" Classes="solid"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- LAYER 3: Resource Rename Interaction Dialog -->
        <Border IsVisible="{Binding RenameDialog.IsInputModalVisible}" ZIndex="100" Background="#aa000000">
            <Border Background="{StaticResource BgPanel}" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="500">
                <StackPanel Spacing="15">
                    <TextBlock Text="{i18N:Localize Rename_Title}" FontSize="20" FontWeight="Bold" Margin="0" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Text="{Binding RenameDialog.NewFileName}" MaxLength="80" Watermark="{i18N:Localize Rename_Label}" 
                             Background="{StaticResource BgApp}" Foreground="{StaticResource TextMuted}" 
                             VerticalAlignment="Center"
                             IsEnabled="{Binding !RenameDialog.IsRenaming}"/>

                    <Border Background="#33E05C5C" BorderBrush="{StaticResource AccentRed}" BorderThickness="1" CornerRadius="4" Padding="12" IsVisible="{Binding RenameDialog.HasRenameError}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="M12 5.99L19.53 19H4.47L12 5.99M12 2L1 21H23L12 2ZM13 16H11V18H13V16ZM13 10H11V15H13V10Z" Width="16" Height="16" Foreground="{StaticResource AccentRed}"/>
                            <TextBlock Text="{Binding RenameDialog.RenameErrorMessage}" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" FontSize="13" VerticalAlignment="Center" MaxWidth="400"/>
                        </StackPanel>
                    </Border>

                    <StackPanel IsVisible="{Binding RenameDialog.IsRenaming}" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Foreground="{StaticResource AccentBlue}" Width="100" VerticalAlignment="Center"/>
                        <TextBlock Text="{i18N:Localize Status_CheckingCloud}" Foreground="{StaticResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" IsEnabled="{Binding !RenameDialog.IsRenaming}">
                        <Button Content="{i18N:Localize Btn_Cancel}" Command="{Binding RenameDialog.CancelRenameCommand}" Classes="outline"/>
                        <Button Content="{i18N:Localize Btn_SaveChanges}" Command="{Binding RenameDialog.ConfirmRenameCommand}" Classes="solid"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- LAYER 4: Destruction Management (Conversation and Attachments) -->
        <Border IsVisible="{Binding DeleteDialog.IsDeleteModalVisible}" ZIndex="100" Background="#aa000000">
            <Border Background="{StaticResource BgPanel}" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="550" MaxWidth="600">
                <StackPanel Spacing="15">
                    
                    <TextBlock Text="{i18N:Localize Delete_Title}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                    
                    <Border Background="#22E05C5C" BorderBrush="{StaticResource AccentRed}" BorderThickness="1" Padding="15" CornerRadius="4" IsVisible="{Binding DeleteDialog.ShowDeleteSyncWarning}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{i18N:Localize Delete_SyncWarn}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                            <CheckBox IsChecked="{Binding DeleteDialog.SkipDeleteWarningCheckbox}" Content="{i18N:Localize Checkbox_DontShow}" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{i18N:Localize Delete_Target}" Foreground="{StaticResource TextMuted}" Margin="0,8,0,-8"/>
                    <TextBlock Text="{Binding DeleteDialog.DeleteTargetName}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>

                    <TextBlock Text="{i18N:Localize Delete_AttachmentLabel}" Foreground="{StaticResource TextMuted}" Margin="0,10,0,-10"/>
                    <ToggleSwitch IsChecked="{Binding DeleteDialog.DeleteAttachmentsToggle}" 
                                   OnContent="{i18N:Localize Delete_AttachOn}" 
                                   OffContent="{i18N:Localize Delete_AttachOff}"
                                   Foreground="{StaticResource TextMuted}"
                                   FontWeight="SemiBold"
                                   IsEnabled="{Binding !DeleteDialog.IsDeleting}"/>

                    <Border Background="{StaticResource BgApp}" BorderBrush="#E0A95C" BorderThickness="1" Padding="12" CornerRadius="4" Margin="0,0,0,0"
                            IsVisible="{Binding DeleteDialog.DeleteAttachmentsToggle}">
                        <Grid ColumnDefinitions="Auto, *">
                            <PathIcon Grid.Column="0" Data="M12 5.99L19.53 19H4.47L12 5.99M12 2L1 21H23L12 2ZM13 16H11V18H13V16ZM13 10H11V15H13V10Z" Width="16" Height="16" Foreground="#E0A95C" VerticalAlignment="Top" Margin="0,2,10,0"/>
                            <TextBlock Grid.Column="1" Text="{i18N:Localize Delete_TrashWarn}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                        </Grid>
                    </Border>

                    <StackPanel IsVisible="{Binding DeleteDialog.IsDeleting}" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" Margin="0,0, 0, 10">
                        <ProgressBar IsIndeterminate="True" Foreground="{StaticResource AccentRed}" Width="100" VerticalAlignment="Center"/>
                        <TextBlock Text="{i18N:Localize Delete_Loading}" Foreground="{StaticResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" IsEnabled="{Binding !DeleteDialog.IsDeleting}">
                        <Button Content="{i18N:Localize Btn_Cancel}" Command="{Binding DeleteDialog.CancelDeleteCommand}" Classes="outline"/>
                        <Button Content="{i18N:Localize Btn_ConfirmDelete}" Command="{Binding DeleteDialog.ConfirmDeleteCommand}" Classes="solid" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

    </Panel>
</UserControl>
