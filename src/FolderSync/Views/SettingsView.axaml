<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FolderSync.ViewModels"
             xmlns:models="using:FolderSync.Models"
             xmlns:i18N="using:FolderSync.MarkupExtensions"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="FolderSync.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             d:DataContext="{x:Static vm:DesignTimeViewModels.SettingsViewModel}"
             x:Name="RootControl">

    <Panel>
        <Grid RowDefinitions="Auto, Auto, *, Auto, Auto" Margin="20" IsEnabled="{Binding !IsAppLocked}">

            <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Spacing="10">
                    <TextBlock Text="{i18N:Localize Settings_Header}" FontSize="20" FontWeight="SemiBold"
                               Margin="0,-10,0,0" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource LightBlue}" Margin="0,-5,0,5" />

                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BgBorder}"
                            BorderThickness="1" CornerRadius="4" Padding="12"
                            HorizontalAlignment="Left" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{i18N:Localize Settings_CurrentMaster}"
                                       Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CurrentMasterName}" FontWeight="SemiBold"
                                       Foreground="{StaticResource LightBlue}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- IMPROVED LAYOUT: Vertical StackPanel right-aligned -->
                <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="5" VerticalAlignment="Top"
                            HorizontalAlignment="Right">

                    <!-- App Version Info (Horizontal) -->
                    <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
                        <TextBlock Text="{i18N:Localize Settings_AppVersion}" Foreground="{StaticResource TextMuted}"
                                   FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding AppVersionDisplay}" Foreground="{StaticResource AccentBlue}"
                                   FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Update Button positioned directly below version info -->
                    <Button Content="{Binding UpdateMessage}"
                            Command="{Binding ShowUpdateModalCommand}"
                            IsVisible="{Binding IsUpdateAvailable}"
                            Classes="outline" CornerRadius="10"
                            Padding="10,4" Margin="0" BorderThickness="1"
                            FontSize="11"
                            HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>

            <!-- Remote Accounts Table with Action Icons -->
            <DataGrid Grid.Row="2" ItemsSource="{Binding SavedRemotes}" SelectedItem="{Binding SelectedRemote}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserResizeColumns="True" MinColumnWidth="60">
                <DataGrid.Columns>


                    <DataGridTemplateColumn Header="" Width="60">
                        <DataTemplate x:DataType="models:RemoteInfo">
                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="5,0">

                                <!-- Action: Set as Master (Round Checkbox) -->
                                <Button Classes="outline"
                                        Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SetAsMasterCommand}"
                                        CommandParameter="{Binding}"
                                        Padding="4" Margin="0" CornerRadius="15" BorderThickness="0"
                                        ToolTip.Tip="{i18N:Localize Btn_SetMaster}">
                                    <Panel>
                                        <!-- Filled green circle with checkmark for Master drive -->
                                        <PathIcon
                                            Data="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM10 17L5 12L6.41 10.59L10 14.17L17.59 6.58L19 8L10 17Z"
                                            Width="18" Height="18" Foreground="{StaticResource AccentGreen}"
                                            IsVisible="{Binding IsMaster}" />
                                        <!-- Empty circle for non-master drives -->
                                        <PathIcon
                                            Data="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM12 20C7.59 20 4 16.41 4 12C4 7.59 7.59 4 12 4C16.41 4 20 7.59 20 12C20 16.41 16.41 20 12 20Z"
                                            Width="18" Height="18" Foreground="{StaticResource TextMuted}"
                                            Opacity="0.5"
                                            IsVisible="{Binding !IsMaster}" />
                                    </Panel>
                                </Button>

                                <!-- Action: Unlink Account (Trash Icon) -->
                                <Button Classes="outline"
                                        Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).StartDeleteRemoteCommand}"
                                        CommandParameter="{Binding}"
                                        Padding="2,4" CornerRadius="4" BorderThickness="0"
                                        ToolTip.Tip="{i18N:Localize Btn_UnlinkAccount}">
                                    <PathIcon
                                        Data="M16 9V19H8V9H16ZM14.5 3H9.5L8.5 4H5V6H19V4H15.5L14.5 3ZM18 7H6V19C6 20.1 6.9 21 8 21H16C17.1 21 18 20.1 18 19V7Z"
                                        Width="16" Height="16" Foreground="{StaticResource AccentRed}" />
                                </Button>

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{i18N:Localize Settings_ColName}" Width="*">
                        <DataTemplate x:DataType="models:RemoteInfo">
                            <StackPanel Orientation="Horizontal" Margin="10,0">
                                <TextBlock Text="{Binding FriendlyName}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="{i18N:Localize Settings_ColRemote}" Binding="{Binding RcloneRemote}"
                                        Width="Auto" />
                    <DataGridTextColumn Header="{i18N:Localize Settings_ColFolderId}" Binding="{Binding FolderId}"
                                        Width="2*" />
                    <DataGridTextColumn Header="{i18N:Localize Settings_ColEmail}" Binding="{Binding Email}" Width="*" />

                    <DataGridTemplateColumn Header="" Width="65">
                        <DataTemplate x:DataType="models:RemoteInfo">
                            <Button Content="folder"
                                    Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).OpenFolderInBrowserCommand}"
                                    CommandParameter="{Binding FolderId}" Classes="outline" CornerRadius="10"
                                    Padding="10,4" Margin="5" BorderThickness="1" VerticalAlignment="Center"
                                    HorizontalAlignment="Center" FontSize="11"
                                    ToolTip.Tip="{i18N:Localize Tooltip_OpenBrowser}" />
                        </DataTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="3" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BgBorder}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,10,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                        <TextBlock Text="{i18N:Localize Settings_Language}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  DisplayMemberBinding="{Binding DisplayName}"
                                  Width="150" Background="{StaticResource BgApp}"
                                  Foreground="{StaticResource TextMuted}" />
                    </StackPanel>

                    <TextBlock Text="{i18N:Localize Settings_PrefHeader}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,10" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <CheckBox IsChecked="{Binding SkipRenameWarningPreference}"
                                  Content="{i18N:Localize Pref_HideRenameWarn}" Foreground="{StaticResource TextMuted}" />
                        <CheckBox IsChecked="{Binding SkipDeleteWarningPreference}"
                                  Content="{i18N:Localize Pref_HideDeleteWarn}" Foreground="{StaticResource TextMuted}" />
                    </StackPanel>

                </StackPanel>
            </Border>


            <Grid Grid.Row="4" ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left">
                    <Button Content="{i18N:Localize Btn_ImportProfile}" Command="{Binding StartImportProfileCommand}"
                            Classes="outline" BorderBrush="#8899A6" Foreground="{StaticResource TextMuted}" />
                    <Button Content="{i18N:Localize Btn_ExportProfile}" Command="{Binding StartExportProfileCommand}"
                            Classes="outline" BorderBrush="{StaticResource AccentGreen}"
                            Foreground="{StaticResource AccentGreen}" />
                </StackPanel>

                <Button Grid.Column="1" Content="{i18N:Localize Btn_AddDrive}" Command="{Binding StartAddDriveCommand}"
                        Classes="solid" />
            </Grid>
        </Grid>

        <!-- OVERLAYS AND MODALS SECTION -->

        <Border IsVisible="{Binding IsOauthModalVisible}" ZIndex="100" Background="#aa000000">
            <Border Background="{StaticResource BgPanel}" CornerRadius="8" Padding="30" HorizontalAlignment="Center"
                    VerticalAlignment="Center" MinWidth="400">
                <StackPanel Spacing="15">
                    <TextBlock Text="{i18N:Localize OAuth_Title}" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" />
                    <ProgressBar IsIndeterminate="True" Foreground="{StaticResource AccentBlue}" Margin="0,0" />
                    <TextBlock Text="{Binding OauthCountdownText}" FontSize="13"
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" />
                    <Button Content="{i18N:Localize Btn_Cancel}" Command="{Binding CancelOauthCommand}"
                            HorizontalAlignment="Center" Margin="0,0,0,0" Classes="solid" />
                </StackPanel>
            </Border>
        </Border>

        <!-- LAYER 3: MODAL 2 (DRIVE CONFIGURATION) -->
        <Border IsVisible="{Binding IsConfigModalVisible}" ZIndex="100" Background="#aa000000">
            <Border Background="{StaticResource BgPanel}" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="500">
                <StackPanel Spacing="15">
                    <TextBlock Text="{i18N:Localize Config_Title}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" />
                    <TextBlock Text="{i18N:Localize Config_Verified}" Foreground="{StaticResource AccentGreen}" FontWeight="SemiBold" Margin="0, 0, 0, -5" />
                    <TextBlock Text="{i18N:Localize Config_NameLabel}" Foreground="{StaticResource TextMuted}" Margin="0,10,0, -10" />
                    <!-- Disabled during verification and read-only during save -->
                    <TextBox Text="{Binding PendingName}" IsEnabled="{Binding !IsVerifyingFolder}" IsReadOnly="{Binding IsSavingDrive}"/>
                    <TextBlock Text="{i18N:Localize Config_RemoteLabel}" Foreground="{StaticResource TextMuted}" Margin="0,10,0, -10" />
                    <TextBox Text="{Binding PendingEmail}" IsReadOnly="True" Background="{StaticResource BgApp}" Foreground="{StaticResource TextMuted}" />
                    <TextBlock Text="{i18N:Localize Config_FolderLabel}" Foreground="{StaticResource TextMuted}" Margin="0,10,0, -10" />

                    <!-- Disabled during folder search or database update -->
                    <TextBox Text="{Binding PendingFolderId}" Watermark="{i18N:Localize Config_FolderWatermark}">
                        <TextBox.IsEnabled>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="!IsVerifyingFolder"/>
                                <Binding Path="!IsSavingDrive"/>
                            </MultiBinding>
                        </TextBox.IsEnabled>
                        <TextBox.IsReadOnly>
                            <Binding Path="IsAutoDetectingFolder" />
                        </TextBox.IsReadOnly>
                    </TextBox>

                    <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsAutoDetectingFolder}" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Foreground="{StaticResource AccentBlue}" Width="80" VerticalAlignment="Center"/>
                        <TextBlock Text="{i18N:Localize Config_AutoDetecting}" Foreground="{StaticResource AccentBlue}" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Combined progress indicator for Folder verification and Mesh saving -->
                    <ProgressBar IsIndeterminate="True" Foreground="{StaticResource AccentGreen}" Margin="0,10">
                        <ProgressBar.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="IsVerifyingFolder"/>
                                <Binding Path="IsSavingDrive"/>
                            </MultiBinding>
                        </ProgressBar.IsVisible>
                    </ProgressBar>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
                        <Button Content="{i18N:Localize Btn_Cancel}" Command="{Binding CancelConfigCommand}" Classes="outline">
                            <Button.IsEnabled>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="!IsVerifyingFolder"/>
                                    <Binding Path="!IsSavingDrive"/>
                                </MultiBinding>
                            </Button.IsEnabled>
                        </Button>
                        <Button Content="{i18N:Localize Btn_Confirm}" Command="{Binding ConfirmConfigCommand}" Classes="solid">
                            <Button.IsEnabled>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="!IsVerifyingFolder"/>
                                    <Binding Path="!IsAutoDetectingFolder"/>
                                    <Binding Path="!IsSavingDrive"/>
                                </MultiBinding>
                            </Button.IsEnabled>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- LAYER 4: MODAL 3 (OVERWRITE WARNING) -->
        <Border IsVisible="{Binding IsOverwriteModalVisible}" ZIndex="100" Background="#aa000000">
            <Border Background="{StaticResource BgApp}" BorderBrush="{StaticResource AccentRed}" BorderThickness="1" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="400">
                <StackPanel Spacing="15">
                    <TextBlock Text="{i18N:Localize Overwrite_Title}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentRed}" />
                    <TextBlock Text="{i18N:Localize Overwrite_Desc1}" TextWrapping="Wrap" />
                    <TextBlock Text="{i18N:Localize Overwrite_Desc2}" TextWrapping="Wrap" />
                    <TextBlock Text="{i18N:Localize Overwrite_Desc3}" TextWrapping="Wrap" FontWeight="Bold" />
                    
                    <StackPanel IsVisible="{Binding IsSavingDrive}" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <ProgressBar IsIndeterminate="True" Foreground="{StaticResource AccentRed}" Width="100" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0" IsEnabled="{Binding !IsSavingDrive}">
                        <Button Content="{i18N:Localize Btn_Cancel}" Command="{Binding CancelOverwriteCommand}" Classes="outline" />
                        <Button Content="{i18N:Localize Btn_ConfirmOverwrite}" Command="{Binding ConfirmOverwriteCommand}" Classes="solid" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- LAYER 5: MODAL 4 (DELETE CONFIRMATION) -->
        <Border IsVisible="{Binding IsDeleteModalVisible}" ZIndex="100" Background="#aa000000">
            <Border Background="{StaticResource BgPanel}" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="450">
                <StackPanel Spacing="15">
                    <TextBlock Text="{i18N:Localize DelConfirm_Title}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentRed}" />

                    <Border Background="{StaticResource BgApp}" Padding="15" CornerRadius="4">
                        <StackPanel Spacing="5">
                            <TextBlock Text="{i18N:Localize DelConfirm_Selected}" Foreground="{StaticResource TextMuted}" FontSize="13" />
                            <TextBlock Text="{Binding RemoteToProcess.FriendlyName}" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextMain}" />
                            <TextBlock Text="{Binding RemoteToProcess.Email}" Foreground="{StaticResource TextMuted}" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{i18N:Localize DelConfirm_Op1}" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" />
                    <TextBlock Text="{i18N:Localize DelConfirm_Op2}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="10,-10,0,0" />
                    <TextBlock Text="{i18N:Localize DelConfirm_Op3}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="10,-10,0,0" />
                    <TextBlock Text="{i18N:Localize DelConfirm_Op4}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextMain}" Margin="10,-10,0,0" />

                    <StackPanel IsVisible="{Binding IsProcessingRemoteAction}" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <ProgressBar IsIndeterminate="True" Foreground="{StaticResource AccentRed}" Width="100" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0" IsEnabled="{Binding !IsProcessingRemoteAction}">
                        <Button Content="{i18N:Localize Btn_Cancel}" Command="{Binding CancelDeleteCommand}" Classes="outline" />
                        <Button Content="{i18N:Localize Btn_ConfirmDelete}" Command="{Binding ConfirmDeleteCommand}" Classes="solid" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- LAYER 6: DATA INTEGRITY MODAL (AUTO-REPAIR) -->
        <Border IsVisible="{Binding IsIntegrityModalVisible}" ZIndex="200" Background="#bb000000">
            <Border Background="{StaticResource BgPanel}" CornerRadius="8" Padding="35" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="550" MaxWidth="600">
                <StackPanel Spacing="15">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Data="M12 5.99L19.53 19H4.47L12 5.99M12 2L1 21H23L12 2ZM13 16H11V18H13V16ZM13 10H11V15H13V10Z" Width="28" Height="28" Foreground="{StaticResource AccentRed}" VerticalAlignment="Center" />
                        <TextBlock Text="{i18N:Localize Integrity_Title}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentRed}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{i18N:Localize Integrity_Desc1}" TextWrapping="Wrap" FontSize="14" Foreground="{StaticResource TextMuted}" />
                    <Border Background="{StaticResource BgApp}" BorderBrush="{StaticResource BgBorder}" BorderThickness="1" Padding="15" CornerRadius="4">
                        <StackPanel Spacing="5">
                            <TextBlock Text="{i18N:Localize Integrity_Desc2}" Foreground="{StaticResource TextMuted}" FontSize="12" />
                            <TextBlock Text="{Binding CorruptedRemotesText}" FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextMain}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{i18N:Localize Integrity_Desc3}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" />
                    
                    <StackPanel IsVisible="{Binding IsProcessingRemoteAction}" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <ProgressBar IsIndeterminate="True" Foreground="{StaticResource AccentRed}" Width="100" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="15" Margin="0,10,0,0" IsEnabled="{Binding !IsProcessingRemoteAction}">
                        <Button Content="{i18N:Localize Btn_Ignore}" Command="{Binding IgnoreIntegrityCommand}" Classes="outline" />
                        <Button Content="{i18N:Localize Btn_AutoRepair}" Command="{Binding AutoRepairIntegrityCommand}" Classes="solid" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border IsVisible="{Binding IsBackupModalVisible}" ZIndex="250" Background="#cc000000">
            <Border Background="{StaticResource BgPanel}" CornerRadius="8" Padding="35" HorizontalAlignment="Center"
                    VerticalAlignment="Center" MinWidth="450" MaxWidth="500">
                <StackPanel Spacing="15">
                    <TextBlock Text="{Binding BackupModalTitle}" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BackupModalDescription}" TextWrapping="Wrap" FontSize="13"
                               Foreground="{StaticResource TextMuted}" TextAlignment="Center" />
                    <TextBlock Text="{i18N:Localize Backup_PasswordLabel}" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" />
                    <TextBox Text="{Binding BackupPassword}" PasswordChar="•"
                             Watermark="{i18N:Localize Backup_PasswordWatermark}" Background="{StaticResource BgApp}"
                             IsEnabled="{Binding !IsBackupProcessing}" />
                    <Border Background="#33E05C5C" BorderBrush="{StaticResource AccentRed}" BorderThickness="1"
                            CornerRadius="4" Padding="12"
                            IsVisible="{Binding BackupErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding BackupErrorMessage}" Foreground="{StaticResource TextMuted}"
                                   TextWrapping="Wrap" FontSize="12" TextAlignment="Center" />
                    </Border>
                    <StackPanel IsVisible="{Binding IsBackupProcessing}" Orientation="Horizontal" Spacing="15"
                                HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Foreground="{StaticResource AccentGreen}" Width="100"
                                     VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="15" Margin="0,10,0,0"
                                IsEnabled="{Binding !IsBackupProcessing}">
                        <Button Content="{i18N:Localize Btn_Cancel}" Command="{Binding CancelBackupCommand}"
                                Classes="outline" />
                        <Button Content="{i18N:Localize Btn_PerformBackup}"
                                Command="{Binding ConfirmBackupOperationCommand}" Classes="solid" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- LAYER 8: APPLICATION UPDATE MODAL -->
        <Border IsVisible="{Binding IsUpdateModalVisible}" ZIndex="300" Background="#cc000000">
            <Border Background="{StaticResource BgPanel}" CornerRadius="8" Padding="35" HorizontalAlignment="Center"
                    VerticalAlignment="Center" MinWidth="400" MaxWidth="500">
                <StackPanel Spacing="15">

                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Text="{i18N:Localize UpdateModal_Title}" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="{i18N:Localize UpdateModal_Desc}" TextWrapping="Wrap" FontSize="14"
                               Foreground="{StaticResource TextMuted}" TextAlignment="Center" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15" Margin="0,10,0,0">
                        <Button Content="{i18N:Localize Btn_Cancel}" Command="{Binding CancelUpdateCommand}"
                                Classes="outline" />
                        <Button Content="{i18N:Localize Btn_DownloadUpdate}" Command="{Binding ConfirmUpdateCommand}"
                                Classes="solid" />
                    </StackPanel>

                </StackPanel>
            </Border>
        </Border>

    </Panel>
</UserControl>